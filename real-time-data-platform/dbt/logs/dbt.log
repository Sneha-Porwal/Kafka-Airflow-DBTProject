  create  table "Ecommerce"."public_gold"."daily_revenue__dbt_tmp"
  
  
    as
  
  (
    

select
  payment_date as date_day,
  sum(amount) as revenue,
  count(distinct order_id) as total_orders,
  avg(amount) as avg_order_value
