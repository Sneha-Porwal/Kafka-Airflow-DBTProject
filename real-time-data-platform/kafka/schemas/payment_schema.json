{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["event_id", "event_timestamp", "payment_id", "order_id", "user_id", "amount", "currency", "payment_method", "payment_status"],
  "properties": {
    "event_id": {"type": "string", "format": "uuid"},
    "event_timestamp": {"type": "string", "format": "date-time"},
    "schema_version": {"type": "string"},
    "payment_id": {"type": "string"},
    "order_id": {"type": "string"},
    "user_id": {"type": "string"},
    "amount": {"type": "number", "minimum": 0},
    "currency": {"type": "string", "enum": ["USD", "EUR", "INR"]},
    "payment_method": {"type": "string", "enum": ["CARD", "UPI", "PAYPAL", "NET_BANKING"]},
    "payment_status": {"type": "string", "enum": ["SUCCESS", "FAILED", "PENDING", "REFUNDED"]}
  },
  "additionalProperties": true
}
